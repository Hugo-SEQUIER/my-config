{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5.3-codex",
  "small_model": "llama/local",
  "default_agent": "build-codex",
  "agent": {
    "build-codex": {
      "description": "Quality-critical implementation agent for production code changes.",
      "mode": "primary",
      "model": "openai/gpt-5.3-codex",
      "options": {
        "reasoningEffort": "high",
        "reasoningSummary": "auto",
        "textVerbosity": "low"
      },
      "permission": {
        "bash": {
          "*": "ask",
          "rtk *": "allow"
        },
        "edit": "ask",
        "question": "allow"
      },
      "steps": 60
    },
    "plan-codex": {
      "description": "Quality-critical planning and debugging agent for hard tasks.",
      "mode": "primary",
      "model": "openai/gpt-5.3-codex",
      "options": {
        "reasoningEffort": "high",
        "reasoningSummary": "auto",
        "textVerbosity": "low"
      },
      "permission": {
        "bash": {
          "*": "ask",
          "rtk *": "allow"
        },
        "edit": "deny",
        "question": "allow"
      },
      "steps": 40
    },
    "build": {
      "description": "Compatibility alias of build-codex.",
      "mode": "primary",
      "model": "openai/gpt-5.3-codex",
      "options": {
        "reasoningEffort": "high",
        "reasoningSummary": "auto",
        "textVerbosity": "low"
      },
      "permission": {
        "bash": {
          "*": "ask",
          "rtk *": "allow"
        },
        "edit": "ask",
        "question": "allow"
      },
      "steps": 60
    },
    "plan": {
      "description": "Compatibility alias of plan-codex.",
      "mode": "primary",
      "model": "openai/gpt-5.3-codex",
      "options": {
        "reasoningEffort": "high",
        "reasoningSummary": "auto",
        "textVerbosity": "low"
      },
      "permission": {
        "bash": {
          "*": "ask",
          "rtk *": "allow"
        },
        "edit": "deny",
        "question": "allow"
      },
      "steps": 40
    },
    "cheap": {
      "description": "Low-cost primary agent for simple, low-risk helper tasks.",
      "mode": "primary",
      "model": "openai/gpt-5.4-mini",
      "options": {
        "reasoningEffort": "low",
        "reasoningSummary": "auto",
        "textVerbosity": "low"
      },
      "permission": {
        "bash": {
          "*": "ask",
          "rtk *": "allow"
        },
        "edit": "deny"
      },
      "steps": 12
    },
    "debug-codex-xhigh": {
      "description": "Escalation agent for very hard debugging, architecture migrations, and security-sensitive analysis.",
      "mode": "subagent",
      "model": "openai/gpt-5.3-codex",
      "options": {
        "reasoningEffort": "xhigh",
        "reasoningSummary": "auto",
        "textVerbosity": "low"
      },
      "permission": {
        "bash": {
          "*": "ask",
          "rtk *": "allow"
        }
      },
      "steps": 24
    },
    "bash-runner": {
      "description": "Utility shell runner for RTK checks, sanity checks, and non-editing commands.",
      "mode": "subagent",
      "model": "llama/local",
      "permission": {
        "bash": {
          "*": "ask",
          "rtk *": "allow"
        },
        "edit": "deny"
      },
      "steps": 6
    },
    "cartography": {
        "description": "Build architecture/docs routing indexes from templates",
        "mode": "subagent",
        "model": "llama/local",
        "steps": 10,
        "permission": {
          "bash": "deny"
        }
    },
    "changelog-keeper": {
      "description": "Maintain changelog entries and lightweight versioning updates.",
      "mode": "subagent",
      "model": "llama/local",
      "permission": {
        "bash": "deny"
      },
      "steps": 8
    },
    "doc-router": {
      "description": "Find canonical docs first and answer from docs before reading code.",
      "mode": "subagent",
      "model": "openai/gpt-5.4-mini",
      "permission": {
        "bash": "deny",
        "edit": "deny",
        "webfetch": "allow"
      },
      "steps": 16
    },
    "plan-critic": {
      "description": "Challenge plans: identify fragile assumptions, risks, and simplifications.",
      "mode": "subagent",
      "model": "openai/gpt-5.4",
      "options": {
        "reasoningEffort": "high",
        "reasoningSummary": "auto",
        "textVerbosity": "low"
      },
      "permission": {
        "bash": "deny",
        "edit": "deny"
      },
      "steps": 12
    },
    "repo-explorer": {
      "description": "Read-only repo exploration with focused grep/glob/read; no edits.",
      "mode": "subagent",
      "model": "openai/gpt-5.4-mini",
      "permission": {
        "bash": "deny",
        "edit": "deny",
        "webfetch": "deny"
      },
      "steps": 20
    },
    "scratch-compactor": {
      "description": "Compact session state into a restart-ready handoff with minimal noise.",
      "mode": "subagent",
      "model": "llama/local",
      "permission": {
        "bash": "deny",
        "edit": "deny",
        "webfetch": "deny"
      },
      "steps": 4
    },
    "vault-bridge": {
      "description": "Run vault-oriented commands and return concise, structured outcomes.",
      "mode": "subagent",
      "model": "llama/local",
      "permission": {
        "bash": {
          "*": "ask",
          "rtk *": "allow"
        },
        "edit": "deny"
      },
      "steps": 6
    }
  },
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 8000
  },
  "mcp": {
    "pencil": {
      "command": [
        "/Applications/Pencil.app/Contents/Resources/app.asar.unpacked/out/mcp-server-darwin-arm64",
        "--app",
        "desktop"
      ],
      "enabled": false,
      "type": "local"
    }
  },
  "provider": {
    "openai": {
      "models": {
        "gpt-5.3-codex": {
          "options": {
            "reasoningEffort": "high",
            "reasoningSummary": "auto",
            "textVerbosity": "low"
          }
        },
        "gpt-5.4-mini": {
          "options": {
            "reasoningEffort": "medium",
            "reasoningSummary": "auto",
            "textVerbosity": "low"
          }
        },
        "gpt-5.4": {
          "options": {
            "reasoningEffort": "high",
            "reasoningSummary": "auto",
            "textVerbosity": "low"
          }
        }
      },
      "options": {
        "setCacheKey": true
      }
    },
    "llama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Local llama.cpp",
      "options": {
        "baseURL": "http://127.0.0.1:8081/v1"
      },
      "models": {
        "local": {
          "name": "Qwen3.6"
        }
      }
    }
  },
  "watcher": {
    "ignore": [
      "node_modules/**",
      "dist/**",
      "build/**",
      ".git/**"
    ]
  },
  "plugin": ["@mohak34/opencode-notifier@latest"]
}
